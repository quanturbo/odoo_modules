<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_real_estate_lead_source_company" model="ir.rule">
            <field name="name">Real Estate Lead Source: company</field>
            <field name="model_id" ref="model_real_estate_lead_source"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        </record>

        <record id="rule_real_estate_lead_inbox_company" model="ir.rule">
            <field name="name">Real Estate Lead Inbox: company</field>
            <field name="model_id" ref="model_real_estate_lead_inbox"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        </record>
    </data>
</odoo>