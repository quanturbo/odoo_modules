<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_groups_privilege_inventory_request" model="res.groups.privilege">
        <field name="name">Inventory Requests</field>
        <field name="sequence">40</field>
    </record>

    <record id="group_stock_request_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="res_groups_privilege_inventory_request" />
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]" />
    </record>

    <record id="group_stock_request_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="res_groups_privilege_inventory_request" />
        <field name="implied_ids" eval="[(4, ref('group_stock_request_user'))]" />
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]" />
    </record>

    <record id="group_stock_request_order" model="res.groups">
        <field name="name">Request Orders</field>
        <field name="privilege_id" ref="res_groups_privilege_inventory_request" />
        <field name="implied_ids" eval="[(4, ref('group_stock_request_user'))]" />
    </record>

    <record id="stock_request_company_rule" model="ir.rule">
        <field name="name">Inventory requests by company</field>
        <field name="model_id" ref="model_stock_request" />
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_stock_request_user')), (4, ref('group_stock_request_manager'))]" />
    </record>

    <record id="stock_request_order_company_rule" model="ir.rule">
        <field name="name">Inventory request orders by company</field>
        <field name="model_id" ref="model_stock_request_order" />
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_stock_request_user')), (4, ref('group_stock_request_manager'))]" />
    </record>

    <record id="stock_request_allocation_company_rule" model="ir.rule">
        <field name="name">Inventory request allocations by company</field>
        <field name="model_id" ref="model_stock_request_allocation" />
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_stock_request_user')), (4, ref('group_stock_request_manager'))]" />
    </record>
</odoo>
